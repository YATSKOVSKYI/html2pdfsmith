{
  "name": "html2pdfsmith",
  "version": "0.1.0",
  "description": "Browserless HTML-to-PDF rendering engine for TypeScript and Bun.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "example": "bun run examples/simple-table.ts",
    "example:css-table": "bun run examples/css-table.ts",
    "example:document": "bun run examples/simple-document.ts",
    "bench": "bun --expose-gc run examples/bench-table.ts",
    "smoke": "bun run examples/smoke.ts"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "@types/pdfkit": "^0.17.6",
    "@types/svg-to-pdfkit": "^0.1.4",
    "domhandler": "^5.0.3",
    "domutils": "^3.2.2",
    "htmlparser2": "^10.0.0",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.18.0",
    "svg-to-pdfkit": "^0.1.8"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.8.0"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}
